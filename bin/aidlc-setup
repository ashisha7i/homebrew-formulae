#!/usr/bin/env bash
set -euo pipefail
REPO_ZIP_URL="https://github.com/awslabs/aidlc-workflows/archive/refs/heads/main.zip"
PATCH_URL="https://raw.githubusercontent.com/ashisha7i/homebrew-formulae/refs/heads/main/aidlc-setup-patch/custom-patch.md"
SESSION_CONTEXT_URL="https://raw.githubusercontent.com/ashisha7i/homebrew-formulae/refs/heads/main/aidlc-setup-patch/.clinerules/session-context.md"
AI_MEMORY_URL="https://raw.githubusercontent.com/ashisha7i/homebrew-formulae/refs/heads/main/aidlc-setup-patch/.ai-memory/ai_memory.py"
VERSION="1.0.18"  # ← update this manually as needed
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/aidlc-workflows"
ZIP_PATH="$CACHE_DIR/main.zip"
EXTRACT_DIR="$CACHE_DIR/main"
EXTRACT_ROOT_GLOB="$EXTRACT_DIR"/aidlc-workflows-*/
PATCH_PATH="$CACHE_DIR/custom-patch.md"
SESSION_CONTEXT_PATH="$CACHE_DIR/session-context.md"
AI_MEMORY_PATH="$CACHE_DIR/ai_memory.py"
FORCE=0
REFRESH=0
usage() {
cat <<EOF
aidlc-setup: install AI-DLC rules for Cline in the current directory
Creates:
  .clinerules/core-workflow.md
  .clinerules/session-context.md
  .aidlc-rule-details/*
  .ai-memory/ai_memory.py
  .gitignore entry for .ai-memory/sessions.db
Options:
  --refresh    re-download latest rules
  --force      overwrite existing files
  --version    show version
  --help       show help
EOF
}
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) FORCE=1 ;;
    --refresh) REFRESH=1 ;;
    --version)
      echo "$VERSION"
      exit 0
      ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1"; usage; exit 1 ;;
  esac
  shift
done
mkdir -p "$CACHE_DIR"
download_if_needed() {
  if [[ "$REFRESH" -eq 1 || ! -f "$ZIP_PATH" ]]; then
    echo "Downloading aidlc workflows..."
    curl -fsSL "$REPO_ZIP_URL" -o "$ZIP_PATH"
  fi
}
download_patch_if_needed() {
  if [[ "$REFRESH" -eq 1 || ! -f "$PATCH_PATH" ]]; then
    echo "Downloading custom patch..."
    curl -fsSL "$PATCH_URL" -o "$PATCH_PATH"
  fi
}
download_session_context_if_needed() {
  if [[ "$REFRESH" -eq 1 || ! -f "$SESSION_CONTEXT_PATH" ]]; then
    echo "Downloading session-context.md..."
    curl -fsSL "$SESSION_CONTEXT_URL" -o "$SESSION_CONTEXT_PATH"
  fi
}
download_ai_memory_if_needed() {
  if [[ "$REFRESH" -eq 1 || ! -f "$AI_MEMORY_PATH" ]]; then
    echo "Downloading ai_memory.py..."
    curl -fsSL "$AI_MEMORY_URL" -o "$AI_MEMORY_PATH"
  fi
}
extract_if_needed() {
  if [[ "$REFRESH" -eq 1 || ! -d "$EXTRACT_DIR" ]]; then
    echo "Extracting rules..."
    rm -rf "$EXTRACT_DIR"
    mkdir -p "$EXTRACT_DIR"
    unzip -q "$ZIP_PATH" -d "$EXTRACT_DIR"
  fi
}
download_if_needed
download_patch_if_needed
download_session_context_if_needed
download_ai_memory_if_needed
extract_if_needed
ROOT="$(ls -d $EXTRACT_ROOT_GLOB 2>/dev/null | head -n 1 || true)"
[[ -n "$ROOT" ]] || { echo "ERROR: extraction failed"; exit 1; }
RULES_ROOT="$ROOT/aidlc-rules"
RULES_DIR="$RULES_ROOT/aws-aidlc-rules"
DETAILS_DIR="$RULES_ROOT/aws-aidlc-rule-details"
CORE="$RULES_DIR/core-workflow.md"
[[ -f "$CORE" ]] || { echo "ERROR: core-workflow.md missing"; exit 1; }
[[ -f "$PATCH_PATH" ]] || { echo "ERROR: custom patch missing"; exit 1; }
[[ -f "$SESSION_CONTEXT_PATH" ]] || { echo "ERROR: session-context.md missing"; exit 1; }
[[ -f "$AI_MEMORY_PATH" ]] || { echo "ERROR: ai_memory.py missing"; exit 1; }
mkdir -p .clinerules
mkdir -p .aidlc-rule-details
mkdir -p .ai-memory
if [[ -f ".clinerules/core-workflow.md" && "$FORCE" -ne 1 ]]; then
  echo "ERROR: .clinerules/core-workflow.md exists (use --force)"
  exit 1
fi
if compgen -G ".aidlc-rule-details/*" > /dev/null && [[ "$FORCE" -ne 1 ]]; then
  echo "ERROR: .aidlc-rule-details not empty (use --force)"
  exit 1
fi
echo "Applying patch and creating core-workflow.md..."
awk 'NR==3{while((getline line < patch) > 0) print line} 1' patch="$PATCH_PATH" "$CORE" > .clinerules/core-workflow.md
rm -rf .aidlc-rule-details/*
cp -R "$DETAILS_DIR/"* .aidlc-rule-details/
echo "Copying session-context.md..."
cp "$SESSION_CONTEXT_PATH" .clinerules/session-context.md
echo "Copying ai_memory.py..."
cp "$AI_MEMORY_PATH" .ai-memory/ai_memory.py
echo "Updating .gitignore..."
if ! grep -qxF '.ai-memory/sessions.db' .gitignore 2>/dev/null; then
  echo '.ai-memory/sessions.db' >> .gitignore
fi
echo
echo "AI-DLC Cline rules installed:"
echo "  .clinerules/core-workflow.md (patched)"
echo "  .clinerules/session-context.md"
echo "  .aidlc-rule-details/*"
echo "  .ai-memory/ai_memory.py"
echo "  .gitignore updated (.ai-memory/sessions.db)"
